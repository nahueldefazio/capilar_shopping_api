# Dependencies
node_modules/

# Uploaded images (stay on server, not in git)
uploads/*
!uploads/.gitkeep

# Environment variables
.env

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store

# IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# TypeORM migrations (generated, not source)
src/migrations/*.js

# TypeScript build artifacts that should not be tracked
dist/src/
dist/test/
dist/tsconfig.tsbuildinfo

# Generated import preview (run npm run import:products:preview to regenerate)
src/database/import-products/imported-products.preview.json
