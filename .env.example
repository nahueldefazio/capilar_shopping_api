# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=capilar_shopping

# ── Frontend ─────────────────────────────────────────────────
# URL del frontend Angular en producción (para CORS)
FRONTEND_URL=https://tu-dominio.com

# ── Mercado Pago ─────────────────────────────────────────────
# Obtené tu Access Token en: https://www.mercadopago.com.ar/developers/panel
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx-xxxx-xxxx-xxxx
MERCADOPAGO_WEBHOOK_SECRET=tu_webhook_secret
